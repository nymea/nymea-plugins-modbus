        {
            "id": "deviceTypeCode",
            "address": 43,
            "size": 1,
            "type": "uint16",
            "readSchedule": "init",
            "registerType": "holdingRegister",
            "description": "Device type code",
            "defaultValue": 0,
            "access": "RO"
        },
        {
            "id": "batteryType",
            "address": 119,
            "size": 1,
            "type": "uint16",
            "readSchedule": "update",
            "registerType": "inputRegister",
            "description": "Battery type",
            "defaultValue": 0,
            "access": "RO"
        }
    ],
