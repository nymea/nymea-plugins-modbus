{
    "className": "Growatt",
    "protocol": "RTU",
    "endianness": "BigEndian",
    "stringEndianness": "BigEndian",
    "errorLimitUntilNotReachable": 15,
    "checkReachableRegister": "deviceTypeCode",
    "queuedRequests": false,
    "queuedRequestsDelay": 0,
