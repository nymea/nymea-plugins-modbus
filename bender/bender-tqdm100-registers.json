            "description": "Energy",
            "unit": "Wh",
            "defaultValue": "0",
            "access": "RO"
        },
        {
            "id": "sessionEnergy",
            "address": 1502,
            "size": 1,
            "type": "uint16",
            "readSchedule": "update",
            "registerType": "holdingRegister",
            "description": "Charged energy for current session",
            "unit": "Wh",
            "defaultValue": "0",
            "access": "RO"
        },
        {
            "id": "chargeCurrent",
            "address": 5004,
            "size": 1,
            "type": "uint16",
            "readSchedule": "update",
            "registerType": "holdingRegister",
            "description": "Charge current",
            "unit": "A",
            "defaultValue": "0",
            "access": "RW"
        },
        {
            "id": "lifeBit",
            "address": 6000,
            "size": 1,
            "type": "uint16",
            "readSchedule": "update",
            "registerType": "holdingRegister",
            "description": "Life bit",
            "defaultValue": "0",
            "access": "RW"
        }
    ]
}
